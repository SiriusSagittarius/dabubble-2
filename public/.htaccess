# DABubble – Apache-Konfiguration für den Production-Build (dist/dabubble/browser)
# Gegenstück zur firebase.json: SPA-Fallback-Routing + COOP-Header + Performance.

# ---------------------------------------------------------------------------
# 1) SPA-Routing: Angular übernimmt das Routing im Client.
#    Echte Dateien/Ordner normal ausliefern, alles andere auf index.html.
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Vorhandene Datei oder Verzeichnis direkt ausliefern.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Alle übrigen Anfragen an die SPA weiterreichen.
  RewriteRule ^ index.html [L]
</IfModule>

# ---------------------------------------------------------------------------
# 2) HTTP-Header
#    - COOP erlaubt dem Firebase-Google-Login-Popup das window.close()
#      (behebt die "Cross-Origin-Opener-Policy would block the window.close"-Warnung).
#    - nosniff als Best-Practice.
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  Header set X-Content-Type-Options "nosniff"

  # index.html darf nicht gecacht werden, damit neue Deployments sofort greifen.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------------
# 3) Komprimierung (Lighthouse-Performance)
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE \
    text/html text/plain text/css \
    text/javascript application/javascript \
    application/json image/svg+xml \
    application/manifest+json
</IfModule>

# ---------------------------------------------------------------------------
# 4) Caching
#    Build-Assets tragen einen Content-Hash im Namen -> langlebig cachebar.
#    (index.html ist oben explizit vom Caching ausgenommen.)
# ---------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType text/javascript         "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
</IfModule>

# ---------------------------------------------------------------------------
# 5) MIME-Typen absichern
# ---------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType application/javascript    .mjs
  AddType image/svg+xml             .svg
  AddType application/manifest+json .webmanifest
  AddType font/woff2                .woff2
</IfModule>
